---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { CATEGORIES, CATEGORY_KEYS, SITE_DESCRIPTION } from '../consts';
import { postUrl, formatDate, byDateDesc } from '../utils';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort(byDateDesc)
  .slice(0, 5);
---

<Base description={SITE_DESCRIPTION}>
  <section class="hero">
    <h1>Hey, I'm Aditya.</h1>
    <p>
      This is my corner of the internet — the stuff going on in my life and the way I
      think about it, split into four buckets. Read enough of it and you'll pretty much
      get me.
    </p>
  </section>

  <ul class="squares">
    {
      CATEGORY_KEYS.map((key) => (
        <li class="square" style={`--accent: ${CATEGORIES[key].color}`}>
          <a href={`/${key}/`}>
            <p class="tagline">{CATEGORIES[key].tagline}</p>
            <h2>{CATEGORIES[key].name}</h2>
            <p class="blurb">{CATEGORIES[key].blurb}</p>
          </a>
        </li>
      ))
    }
  </ul>

  {
    posts.length > 0 && (
      <section>
        <p class="section-label">Recent posts</p>
        <ul class="post-list">
          {posts.map((post) => (
            <li style={`--accent: ${CATEGORIES[post.data.category].color}`}>
              <a class="post-title" href={postUrl(post)}>
                {post.data.title}
              </a>
              <p class="post-meta">
                <a class="chip" href={`/${post.data.category}/`}>
                  {CATEGORIES[post.data.category].name}
                </a>
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
              </p>
              <p class="post-desc">{post.data.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Base>
