---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { CATEGORIES, CATEGORY_KEYS, SITE_DESCRIPTION } from '../consts';
import { postUrl, formatDate, byDateDesc } from '../utils';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort(byDateDesc)
  .slice(0, 6);
---

<Base description={SITE_DESCRIPTION} full>
  <div class="home-fill">
    <section class="hero">
      <h1>Hey, I'm Aditya.</h1>
      <p>
        This is my corner of the internet — the stuff going on in my life and the way I
        think about it, split into four buckets. Read enough of it and you'll pretty
        much get me.
      </p>
    </section>

    <div class="tiles">
      {
        CATEGORY_KEYS.map((key) => (
          <a class="tile" href={`/${key}/`}>
            <h2>{CATEGORIES[key].name}</h2>
            <p class="blurb">{CATEGORIES[key].blurb}</p>
          </a>
        ))
      }
    </div>
  </div>

  {
    posts.length > 0 && (
      <section class="recent">
        <p class="section-label">Recent posts</p>
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a class="post-title" href={postUrl(post)}>
                {post.data.title}
              </a>
              <p class="post-meta">
                <a class="chip" href={`/${post.data.category}/`}>
                  {CATEGORIES[post.data.category].name}
                </a>
                <time datetime={post.data.pubDate.toISOString()}>
                  {formatDate(post.data.pubDate)}
                </time>
              </p>
              <p class="post-desc">{post.data.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }
</Base>
